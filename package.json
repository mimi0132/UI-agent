{
  "name": "vue-ui-agent",
  "version": "1.0.0",
  "description": "从 UI 截图一键生成完整前端组件库（Vue 3 / React），支持 Gemini、GPT、Claude、DeepSeek 等主流 AI 模型。Agent Skill 模式，npx skills 一键安装。",
  "type": "module",
  "bin": {
    "vue-ui-agent": "./src/cli.js"
  },
  "files": [
    "src/",
    "skills/",
    "README.md",
    "SKILL.md",
    "CHANGELOG.md",
    "LICENSE",
    ".gitignore"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/cli.js",
    "preview": "node src/preview.js",
    "lint": "node src/lint.js",
    "check": "npm run lint && node -e \"import('./src/core.js');import('./src/cli.js');import('./src/preview.js');console.log('✅ 所有模块检查通过')\"",
    "test:install": "node -e \"console.log('测试安装入口')\" && node src/cli.js --help"
  },
  "keywords": [
    "vue",
    "react",
    "ui-agent",
    "component-generator",
    "agent-skill",
    "cursor",
    "claude-code",
    "gemini",
    "openai",
    "claude",
    "design-system",
    "design-tokens",
    "screenshot-to-code"
  ],
  "author": "mimi0132",
  "license": "MIT",
  "homepage": "https://github.com/mimi0132/vue-ui-agent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimi0132/vue-ui-agent.git"
  },
  "bugs": {
    "url": "https://github.com/mimi0132/vue-ui-agent/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "openai": "^4.73.0",
    "zod": "^3.23.8"
  }
}
